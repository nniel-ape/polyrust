# Polyrust Trading Bot — Environment Variables
#
# Copy to .env and fill in your values. Never commit .env to git.
# These replace the former [polymarket] section in config.toml.

# Wallet credentials (REQUIRED for live trading)
POLY_PRIVATE_KEY=
POLY_SAFE_ADDRESS=

# Builder API credentials (REQUIRED for live trading)
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# Polygon RPC endpoints for Chainlink oracle queries (comma-separated, tried in order)
POLY_RPC_URLS=https://polygon-rpc.com

# Gasless relayer (default: true when builder credentials are present)
POLY_USE_RELAYER=true
# POLY_RELAYER_URL=https://relayer-v2.polymarket.com

# Tunnel (SSH SOCKS proxy through secondary VPS)
TUNNEL_SSH_USER=root
TUNNEL_SSH_PORT=22
